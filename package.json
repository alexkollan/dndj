{
  "name": "dndj",
  "version": "1.0.0",
  "description": "DJ-style soundboard and music manager for Dungeon Masters",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev:vite": "vite",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5178 && electron .\"",
    "build:vite": "vite build",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "dnd",
    "soundboard",
    "electron",
    "dungeon-master"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-reloader": "^1.2.3",
    "howler": "^2.2.4",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-rebuild": "^3.2.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
